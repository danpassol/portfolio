---
import { languages, defaultLang } from '~/i18n/ui';
import { isRtl, useTranslations } from '~/i18n/utils';
import { Image } from 'astro:assets';
import bentoCode from '~/assets/bento-code.jpg';
import grafanaDash from '~/assets/grafana-dashboard.png'
import haCluster from '~/assets/ha-cluster.png'
import Layout from '~/layouts/Layout.astro';
import Schema from '~/components/layout/Schema.astro';
import Hero from '~/components/sections/Hero.astro';
import Section from '~/components/layout/Section.astro';
// posts execution moved to LatestPosts component
import LatestPosts from '~/components/sections/LatestPosts.astro';
import BentoGrid from '~/components/sections/BentoGrid.astro';
import BentoItem from '~/components/ui/BentoItem.astro';
import { Cpu, Globe, Zap, BarChart, ShieldCheck, Settings, FileCode, Search, Moon, Eye } from 'lucide-react';
import FeaturesList from '~/components/sections/FeaturesList.astro';
import FeatureItem from '~/components/ui/FeatureItem.astro';


import CTA from '~/components/sections/CTA.astro';
import FAQ from '~/components/sections/FAQ.astro';
import TechStack from '~/components/sections/TechStack.astro';

export async function getStaticPaths() {
  return Object.keys(languages).map((lang) => ({ params: { lang } }));
}

const { lang = defaultLang } = Astro.params;
const t = useTranslations(lang);



---

<Layout>
    <Schema item={{
            "@context": "https://schema.org",
            "@type": "WebSite",
            "name": "dpastor.eu",
            "url": Astro.site,
            "potentialAction": {
                "@type": "SearchAction",
                "target": {
                    "@type": "EntryPoint",
                    "urlTemplate": `${Astro.site}/search?q={search_term_string}`
                },
                "query-input": "required name=search_term_string"
            }
        }} />
    <Schema item={{
            "@context": "https://schema.org",
            "@type": "ProfilePage",
            "name": "dpastor.eu",
            "operatingSystem": "Web",
            "applicationCategory": "DeveloperApplication",
            "offers": {
                "@type": "Offer",
                "price": "0",
                "priceCurrency": "EUR"
            },
            "aggregateRating": {
                "@type": "AggregateRating",
                "ratingValue": "4.9",
                "ratingCount": "120"
            }
        }} />
	
    <Hero 
        title={t['hero.title']}
        highlight={t['hero.highlight']}
        description1={t['hero.subtitle1']}
        description2={t['hero.subtitle2']}
        primaryCta={{ text: t['hero.getStarted'], href: `/${lang}/contact` }}
        secondaryCta={{ text: t['hero.learnMore'], href: `/${lang}/about` }}
    />
    

    <Section class="py-0 overflow-visible">
    <BentoGrid 
        title={t['bento.title']}
        description={t['bento.description']}
    >
        <BentoItem class="md:col-span-2 group">
            
            <div slot="background" class="absolute inset-0 z-0 pointer-events-none overflow-hidden">
                <Image 
                    src={haCluster} 
                    alt="Cluster" 
                    class="absolute inset-0 w-full h-full object-cover group-hover:scale-105 transition-transform duration-700 z-0" 
                />
            </div>
            
            <div class="grow flex flex-col justify-between relative z-10 h-full">
                <div>
                    <div class="w-12 h-12 rounded-xl bg-primary/10 dark:bg-white/10 flex items-center justify-center mb-6 relative z-10">
                        <Globe className="w-6 h-6 text-primary dark:text-white" />
                    </div>
                    <h3 class="text-2xl font-bold mb-2 text-foreground relative z-10">{t['bento.item1.title']}</h3>
                    <p class="text-muted-foreground relative z-10 mb-2">{t['bento.item1.desc']}</p>
                </div>
                
                <div class="w-full h-20 bg-foreground/5 rounded-xl border border-foreground/8 backdrop-blur-sm overflow-hidden relative z-10">
                    <div class="absolute inset-0 flex items-center justify-center">
                        <div class="text-xs font-mono text-primary/90 font-bold text-center">
                            checking pods status... <br/>
                            quantity: 4 | status: <span class="text-emerald-600 dark:text-emerald-500">healthy</span>
                        </div>
                    </div>
                </div>
            </div>
        </BentoItem>

        <BentoItem class="md:row-span-2 group">
            
            <div slot="background" class="absolute inset-0 z-0 pointer-events-none overflow-hidden">
                <Image 
                    src={bentoCode} 
                    alt="Code" 
                    class="absolute inset-0 w-full h-full object-cover group-hover:scale-105 transition-transform duration-700 z-0" 
                />
            </div>
            
            <div class="grow flex flex-col justify-end relative z-20 h-full">
                <div class="w-12 h-12 rounded-xl bg-primary flex items-center justify-center mb-4 relative z-10">
                    <Cpu className="w-6 h-6 text-white" />
                </div>
                <h3 class="text-2xl font-bold mb-2 text-foreground relative z-10">{t['bento.item2.title']}</h3>
                <p class="text-muted-foreground text-sm relative z-10">{t['bento.item2.desc']}</p>
            </div>
        </BentoItem>

        <BentoItem class="group">
            
            <div slot="background"></div>
            
            <div class="grow flex flex-col justify-center text-center h-full relative z-10">
                <div class="w-12 h-12 rounded-full bg-blue-500/20 text-blue-400 flex items-center justify-center mx-auto mb-4 relative z-10">
                    <Zap className="w-6 h-6" />
                </div>
                <h3 class="text-lg font-bold text-foreground relative z-10">{t['bento.item3.title']}</h3>
                <p class="text-sm text-muted-foreground mt-2 relative z-10">{t['bento.item3.desc']}</p>
            </div>
        </BentoItem>

        <BentoItem class="group">
            
            <div slot="background"></div>
            
            <div class="grow flex flex-col justify-center text-center h-full relative z-10">
                <div class="w-12 h-12 rounded-full bg-green-500/20 text-green-400 flex items-center justify-center mx-auto mb-4 relative z-10">
                    <ShieldCheck className="w-6 h-6" />
                </div>
                <h3 class="text-lg font-bold text-foreground relative z-10">{t['bento.item4.title']}</h3>
                <p class="text-sm text-muted-foreground mt-2 relative z-10">{t['bento.item4.desc']}</p>
            </div>
        </BentoItem>
        
        <BentoItem class="md:col-span-3 group">
            
            <div slot="background">
                <Image 
                    src={grafanaDash} 
                    alt="Dashboard" 
                    class="absolute inset-0 w-full h-full object-cover group-hover:scale-105 transition-transform duration-700 z-0" 
                />
            </div>
            
            <div class="grow flex items-center justify-between gap-8 h-full relative z-10">
                <div class="relative z-10 flex flex-col grow">
                    <h3 class="text-2xl font-bold mb-2 text-foreground">{t['bento.item5.title']}</h3>
                    <p class="text-muted-foreground max-w-sm">{t['bento.item5.desc']}</p>
                </div>
                
                <div class="relative z-10 w-32 h-32 shrink-0 bg-linear-to-tr from-primary to-purple-500 rounded-2xl flex items-center justify-center shadow-lg transform rotate-6 group-hover:rotate-12 transition-transform">
                    <BarChart className="w-16 h-16 text-white" />
                </div>
            </div>
        </BentoItem>
    </BentoGrid>
    </Section>

    <Section class="p-5 flex flex-col items-center">
        <div class="text-center max-w-3xl mx-auto mb-16">
            <h2 class="text-3xl font-bold mb-4">{t['benefits.title']}</h2>
            <p class="text-muted-foreground">{t['benefits.subtitle']}</p>
        </div>
        <FeaturesList>
            <FeatureItem title={t['benefits.1.title']} description={t['benefits.1.desc']}>
                <Settings slot="icon" className="w-6 h-6" />
            </FeatureItem>
            <FeatureItem title={t['benefits.2.title']} description={t['benefits.2.desc']}>
                <FileCode slot="icon" className="w-6 h-6" />
            </FeatureItem>
            <FeatureItem title={t['benefits.3.title']} description={t['benefits.3.desc']}>
                <Search slot="icon" className="w-6 h-6" />
            </FeatureItem>
            <FeatureItem title={t['benefits.4.title']} description={t['benefits.4.desc']}>
                <Moon slot="icon" className="w-6 h-6" />
            </FeatureItem>
            <FeatureItem title={t['benefits.5.title']} description={t['benefits.5.desc']}>
                <Eye slot="icon" className="w-6 h-6" />
            </FeatureItem>
            <FeatureItem title={t['benefits.6.title']} description={t['benefits.6.desc']}>
                <Globe slot="icon" className="w-6 h-6" />
            </FeatureItem>
        </FeaturesList>
    </Section>

    <Section id="tech-stack" class="py-24 bg-foreground/2">
        <div class="text-center max-w-3xl mx-auto mb-16">
            <h2 class="text-3xl font-bold mb-4 italic">{t['techstack.title']}</h2>
            <p class="text-muted-foreground">{t['techstack.subtitle']}</p>
        </div>
        <div class="max-w-6xl mx-auto px-6">
            <TechStack t={t} />
        </div>
    </Section>

    <Section>
        <LatestPosts count={6}/>
    </Section>

    <Section class="py-0 overflow-visible">
    <FAQ items={[
        {
          question: t['faq.home.1.q'],
          answer: t['faq.home.1.a']
        },
        {
          question: t['faq.home.2.q'],
          answer: t['faq.home.2.a']
        },
        {
          question: t['faq.home.3.q'],
          answer: t['faq.home.3.a']
        },
        {
          question: t['faq.home.4.q'],
          answer: t['faq.home.4.a']
        },
        {
          question: t['faq.home.5.q'],
          answer: t['faq.home.5.a']
        }
    ]} />
    </Section>

    <CTA 
        title={t['cta.readyToLaunch']}
        description={t['cta.description']}
        primaryBtn={{ text: t['cta.primary'], href: `/${lang}/contact` }}
        secondaryBtn={{ text: t['cta.secondary'], href: `/${lang}/projects` }}
        disclaimer={t['cta.disclaimer']}
    />

</Layout>