---
import Layout from '~/layouts/Layout.astro';
import PageHeader from '~/components/layout/PageHeader.astro';
import Button from '~/components/ui/Button.astro';
import BlogCard from '~/components/blog/BlogCard.astro';
import Container from '~/components/ui/Container.astro';
import Grid from '~/components/ui/Grid.astro';
import { getCollection } from 'astro:content';
import { siteConfig } from '~/site.config';

import { languages, defaultLang } from '~/i18n/ui';
import { useTranslations } from '~/i18n/utils';

import type { GetStaticPathsOptions, Page } from 'astro';
import type { CollectionEntry } from 'astro:content';

type PostWithMeta = {
  post: CollectionEntry<'blog'>;
  unavailable: boolean;
  postLang: string;
};

export async function getStaticPaths({ paginate }: { paginate: GetStaticPathsOptions['paginate'] }) {
  const allPosts = (await getCollection('blog')).sort(
    (a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf()
  );

  return Object.keys(languages).flatMap((lang) => {
    const fallbackLang = Object.keys(languages).find(l => l !== lang) || defaultLang;

    const nativePosts: PostWithMeta[] = allPosts
      .filter(post => post.id.startsWith(`${lang}/`))
      .map(post => ({ post, unavailable: false, postLang: lang }));

    const nativeIds = new Set(
      nativePosts.map(({ post }) => post.id.split('/').slice(1).join('/'))
    );

    const fallbackPosts: PostWithMeta[] = allPosts
      .filter(post => post.id.startsWith(`${fallbackLang}/`))
      .map(post => ({ post, unavailable: true, postLang: fallbackLang }));

    // Mezclar: nativos primero, luego fallback, ordenados por fecha
    const mixed = [...nativePosts, ...fallbackPosts].sort(
      (a, b) => b.post.data.pubDate.valueOf() - a.post.data.pubDate.valueOf()
    );

    return paginate(mixed, {
      params: { lang },
      pageSize: siteConfig.blog.postsPerPage
    });
  });
}

const { page } = Astro.props as { page: Page<PostWithMeta> };
const { lang } = Astro.params;
const t = useTranslations(lang);
---

<Layout siteTitle="Blog" description="Read our latest articles">
  <PageHeader 
      title={t['blog.hero.title']}
      description={t['blog.hero.subtitle']}
  />

  <Container as="section" class="pb-24">
      <Grid cols={3} class="mb-16">
        {page.data.map(({ post, unavailable, postLang }) => (
          <BlogCard 
             title={post.data.title}
             description={post.data.description}
             pubDate={post.data.pubDate}
             heroImage={post.data.heroImage}
             slug={`/${postLang}/blog/${post.id.split('/').slice(1).join('/').replace(/\.[^/.]+$/, "")}`}
             isVideo={post.data.isVideo}
             unavailable={unavailable}
          />
        ))}
      </Grid>
      
      <div class="flex items-center justify-center gap-4">
        {page.url.prev && (
            <Button href={page.url.prev} variant="outline" class="gap-2 px-6 py-3 rounded-full bg-white dark:bg-zinc-800">
                ← {t['blog.prev']}
            </Button>
        )}
        
        <span class="text-sm font-bold text-muted-foreground">
            {t['blog.page']} {page.currentPage} {t['blog.of']} {page.lastPage}
        </span>

        {page.url.next && (
            <Button href={page.url.next} variant="outline" class="gap-2 px-6 py-3 rounded-full bg-white dark:bg-zinc-800">
                {t['blog.next']} →
            </Button>
        )}
      </div>
  </Container>
</Layout>