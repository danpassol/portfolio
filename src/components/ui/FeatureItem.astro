---
interface Props {
  title: string;
  description: string;
  children?: any;
}

const { title, description } = Astro.props;
---

<div class="relative group p-8 h-full rounded-2xl overflow-hidden transition-all duration-500 ease-out hover:-translate-y-1 bg-(--surface-2) border border-(--surface-border) hover:border-primary/30 hover:shadow-[0_12px_40px] hover:shadow-primary/10">
  
  <div class="absolute inset-0 bg-linear-to-br from-primary/10 via-transparent to-transparent opacity-0 group-hover:opacity-100 transition-opacity duration-500 pointer-events-none z-0"></div>

  <div class="relative z-10 flex flex-col items-start h-full">
    
    <div class="w-12 h-12 rounded-xl flex items-center justify-center mb-6 transition-transform duration-300 group-hover:scale-110 bg-primary/10 border border-primary/20 text-primary">
      <slot name="icon" />
    </div>

    <h3 class="text-lg font-semibold mb-3 transition-colors duration-300 group-hover:text-primary">
      {title}
    </h3>

    <p class="text-sm leading-relaxed grow text-muted-foreground">
      {description}
    </p>
  </div>
</div>