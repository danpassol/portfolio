---
import { clsx } from 'clsx';
import { twMerge } from 'tailwind-merge';

interface Props {
  variant?: 'primary' | 'secondary' | 'outline' | 'ghost' | 'icon';
  size?: 'sm' | 'md' | 'lg';
  class?: string;
  href?: string;
  target?: string;
  rel?: string;
  [key: string]: any; // Allow other props like onClick, type, etc.
}

const { 
    variant = 'primary', 
    size = 'md', 
    class: className,
    ...rest 
} = Astro.props;

const baseStyles = 'inline-flex items-center justify-center font-medium transition-colors focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-ring disabled:pointer-events-none disabled:opacity-50 whitespace-nowrap';

const variants = {
  primary: 'text-white font-semibold shadow-lg transition-all duration-300',
  secondary: 'border text-foreground/80 hover:text-foreground transition-all duration-200',
  outline: 'border bg-transparent transition-all duration-200 text-foreground',
  ghost: 'text-primary hover:bg-primary/5 transition-colors',
  icon: 'p-0 aspect-square hover:bg-foreground/5 rounded-full transition-colors'
};

const sizes = {
  sm: 'text-xs px-3 py-1.5 rounded-md gap-1.5',
  md: 'text-sm px-6 py-2.5 rounded-lg gap-2',
  lg: 'text-base px-8 py-3 rounded-xl gap-2.5'
};

// Override size for icon variant
const sizeStyles = variant === 'icon' ? 'h-9 w-9' : sizes[size];

const classes = twMerge(
    baseStyles, 
    variants[variant], 
    sizeStyles,
    className
);

const Tag = Astro.props.href ? 'a' : 'button';

const inlineStyle = variant === 'primary'
  ? 'background: linear-gradient(135deg, #4a8fe8, #3b7dd8); box-shadow: 0 0 22px rgba(74,143,232,0.3), inset 0 1px 0 rgba(255,255,255,0.08);'
  : variant === 'secondary'
  ? 'border-color: rgba(74,143,232,0.2); background: rgba(74,143,232,0.04); color: rgba(176,196,230,0.8);'
  : variant === 'outline'
  ? 'border-color: rgba(74,143,232,0.25); color: rgba(240,244,255,0.85);'
  : '';
---

<Tag class={classes} style={inlineStyle} {...rest}>
    <slot />
</Tag>