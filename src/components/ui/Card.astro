---
import { twMerge } from 'tailwind-merge';
import clsx from 'clsx';

interface Props {
  as?: string;
  href?: string;
  class?: string;
  [key: string]: any;
}

const { as, href, class: className, ...rest } = Astro.props;

const Tag = as || (href ? 'a' : 'div');
---

<Tag
  href={href}
  class={twMerge(
    clsx(
      "block p-6 rounded-2xl transition-all duration-300",
      href && "hover:-translate-y-1 cursor-pointer group",
      className
    )
  )}
  style={`background: var(--surface-2); border: 1px solid var(--surface-border); backdrop-filter: blur(12px);${href ? ' ' : ''}`}
  onmouseover={href ? "this.style.borderColor='rgba(74,143,232,0.28)'; this.style.boxShadow='0 8px 32px rgba(74,143,232,0.1)'" : undefined}
  onmouseout={href ? "this.style.borderColor='rgba(74,143,232,0.12)'; this.style.boxShadow='none'" : undefined}
  {...rest}
>
  <slot />
</Tag>