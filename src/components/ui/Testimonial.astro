---
interface Props {
  text: string;
  author: string;
  role: string;
  children?: any;
}

const { text, author, role } = Astro.props;
---

<div class="w-85 shrink-0 p-7 rounded-2xl transition-all duration-300"
  style="background: var(--surface-2); border: 1px solid rgba(74,143,232,0.12);"
  onmouseover="this.style.borderColor='rgba(74,143,232,0.28)'; this.style.boxShadow='0 8px 32px rgba(74,143,232,0.08)'"
  onmouseout="this.style.borderColor='rgba(74,143,232,0.12)'; this.style.boxShadow='none'"
>
  <p class="text-sm mb-5 leading-relaxed text-muted-foreground">"{text}"</p>
  <div class="flex items-center gap-3">
    <div class="w-9 h-9 rounded-full flex items-center justify-center font-bold text-white text-sm shrink-0"
      style="background: linear-gradient(135deg, #4a8fe8, #7c5cfc);">
      {author[0]}
    </div>
    <div>
      <div class="text-sm font-semibold text-foreground">{author}</div>
      <div class="text-xs text-muted-foreground/70">{role}</div>
    </div>
  </div>
</div>