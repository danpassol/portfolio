---
import { clsx } from 'clsx';
import { 
  Terminal,
  Container,
  Bot,
  Server,
  ShieldCheck,
  BarChart2,
  Network,
  Activity
} from 'lucide-react';

interface Props {
  t: any;
}

const { t } = Astro.props;

// 1. Definimos las claves de los colores que estamos usando
type ThemeKey = 'yellow' | 'blue' | 'red' | 'orange' | 'green' | 'orangeDark' | 'cyan' | 'pink';

// 2. Creamos el diccionario con todas las clases específicas para cada estado y color
const THEME_COLORS: Record<ThemeKey, any> = {
  yellow: {
    icon: 'text-yellow-400',
    iconBgHover: 'group-hover:bg-yellow-400/10',
    border: 'hover:border-yellow-400/40',
    shadow: 'hover:shadow-yellow-400/15',
    text: 'group-hover:text-yellow-400',
    glow: 'group-hover:bg-yellow-400/2',
  },
  blue: {
    icon: 'text-blue-400',
    iconBgHover: 'group-hover:bg-blue-400/10',
    border: 'hover:border-blue-400/40',
    shadow: 'hover:shadow-blue-400/15',
    text: 'group-hover:text-blue-400',
    glow: 'group-hover:bg-blue-400/2',
  },
  red: {
    icon: 'text-red-400',
    iconBgHover: 'group-hover:bg-red-400/10',
    border: 'hover:border-red-400/40',
    shadow: 'hover:shadow-red-400/15',
    text: 'group-hover:text-red-400',
    glow: 'group-hover:bg-red-400/2',
  },
  orange: {
    icon: 'text-orange-400',
    iconBgHover: 'group-hover:bg-orange-400/10',
    border: 'hover:border-orange-400/40',
    shadow: 'hover:shadow-orange-400/15',
    text: 'group-hover:text-orange-400',
    glow: 'group-hover:bg-orange-400/2',
  },
  green: {
    icon: 'text-green-400',
    iconBgHover: 'group-hover:bg-green-400/10',
    border: 'hover:border-green-400/40',
    shadow: 'hover:shadow-green-400/15',
    text: 'group-hover:text-green-400',
    glow: 'group-hover:bg-green-400/2',
  },
  orangeDark: {
    icon: 'text-orange-500',
    iconBgHover: 'group-hover:bg-orange-500/10',
    border: 'hover:border-orange-500/40',
    shadow: 'hover:shadow-orange-500/15',
    text: 'group-hover:text-orange-500',
    glow: 'group-hover:bg-orange-500/2',
  },
  cyan: {
    icon: 'text-cyan-400',
    iconBgHover: 'group-hover:bg-cyan-400/10',
    border: 'hover:border-cyan-400/40',
    shadow: 'hover:shadow-cyan-400/15',
    text: 'group-hover:text-cyan-400',
    glow: 'group-hover:bg-cyan-400/2',
  },
  pink: {
    icon: 'text-pink-400',
    iconBgHover: 'group-hover:bg-pink-400/10',
    border: 'hover:border-pink-400/40',
    shadow: 'hover:shadow-pink-400/15',
    text: 'group-hover:text-pink-400',
    glow: 'group-hover:bg-pink-400/2',
  }
};

interface TechItem {
  id: string;
  name: string;
  icon: any;
  category: 'sistemas' | 'contenedores' | 'automatizacion' | 'virtualizacion' | 'seguridad' | 'monitorizacion' | 'red' | 'aplicaciones';
  theme: ThemeKey; // Cambiamos 'color' por 'theme'
}

// 3. Asignamos la clave del tema a cada item
const TECH_STACK: TechItem[] = [
  {
    id: 'linux',
    name: 'Linux',
    icon: Terminal,
    category: 'sistemas',
    theme: 'yellow',
  },
  {
    id: 'docker',
    name: 'Docker / k3s',
    icon: Container,
    category: 'contenedores',
    theme: 'blue',
  },
  {
    id: 'ansible',
    name: 'Ansible / Terraform',
    icon: Bot,
    category: 'automatizacion',
    theme: 'red',
  },
  {
    id: 'proxmox',
    name: 'Proxmox / VMware',
    icon: Server,
    category: 'virtualizacion',
    theme: 'orange',
  },
  {
    id: 'wazuh',
    name: 'Wazuh / Suricata',
    icon: ShieldCheck,
    category: 'seguridad',
    theme: 'green',
  },
  {
    id: 'grafana',
    name: 'Grafana / Prometheus',
    icon: BarChart2,
    category: 'monitorizacion',
    theme: 'orangeDark',
  },
  {
    id: 'opnsense',
    name: 'OPNsense',
    icon: Network,
    category: 'red',
    theme: 'cyan',
  },
  {
    id: 'uptimekuma',
    name: 'Uptime Kuma / ERPNext',
    icon: Activity,
    category: 'aplicaciones',
    theme: 'pink',
  }
];

const CATEGORY_COLORS = {
  sistemas:       'bg-yellow-600/10 text-yellow-900 dark:text-yellow-300 border-yellow-600/20',
  contenedores:   'bg-blue-600/10 text-blue-950 dark:text-blue-300 border-blue-600/20',
  automatizacion: 'bg-red-600/10 text-red-950 dark:text-red-300 border-red-600/20',
  virtualizacion: 'bg-orange-600/10 text-orange-950 dark:text-orange-300 border-orange-600/20',
  seguridad:      'bg-green-600/10 text-green-950 dark:text-green-300 border-green-600/20',
  monitorizacion: 'bg-orange-600/10 text-orange-950 dark:text-orange-300 border-orange-600/20',
  red:            'bg-cyan-600/10 text-cyan-950 dark:text-cyan-300 border-cyan-600/20',
  aplicaciones:   'bg-pink-600/10 text-pink-950 dark:text-pink-300 border-pink-600/20',
};
---

<div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-4">
  {TECH_STACK.map((tech) => {
    // Extraemos el tema para tener un código más limpio abajo
    const theme = THEME_COLORS[tech.theme];

    return (
      <div class={clsx(
        "group relative p-6 rounded-2xl border border-foreground/15 bg-background/95 backdrop-blur-sm transition-all duration-300 hover:shadow-xl hover:-translate-y-1",
        theme.border,
        theme.shadow
      )}>
        <div class="flex items-start justify-between mb-4">
          <div class={clsx("p-3 rounded-xl bg-foreground/5 transition-colors", theme.icon, theme.iconBgHover)}>
            <tech.icon className="w-6 h-6" />
          </div>
          <span class={clsx("text-[10px] uppercase tracking-wider font-bold px-2 py-0.5 rounded-full border transition-colors", CATEGORY_COLORS[tech.category])}>
            {t[`techstack.category.${tech.category}`]}
          </span>
        </div>
        
        <h3 class={clsx("text-lg font-bold mb-1 transition-colors italic", theme.text)}>
          {tech.name}
        </h3>
        <p class="text-sm text-foreground/90 dark:text-foreground/80 leading-relaxed font-medium">
          {t[`techstack.item.${tech.id}.desc`]}
        </p>

        {/* Background Glow */}
        <div class={clsx("absolute inset-0 rounded-2xl bg-primary/0 transition-colors -z-1", theme.glow)} />
      </div>
    );
  })}
</div>