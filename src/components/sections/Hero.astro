---
import { ui, defaultLang } from '~/i18n/ui';
import { useTranslations } from '~/i18n/utils';

interface Props {
  badge?: string;
  title?: string;
  highlight?: string;
  description1?: string;
  description2?: string;
  primaryCta?: { text: string; href: string };
  secondaryCta?: { text: string; href: string };
}

const { lang = defaultLang } = Astro.params;
const t = useTranslations(lang);

const {
  badge = t['hero.badge'],
  title = t['hero.title'],
  highlight = t['hero.highlight'],
  description1 = t['hero.subtitle1'],
  description2 = t['hero.subtitle2'],
  primaryCta = { text: t['hero.getStarted'], href: "/contact" },
  secondaryCta = { text: t['hero.learnMore'], href: "/about" }
} = Astro.props;
---

<section class="relative min-h-[92vh] flex items-center justify-center overflow-hidden pt-20">
  <div class="absolute inset-0 z-0 pointer-events-none" aria-hidden="true">
    <div class="absolute top-[25%] left-1/2 -translate-x-1/2 w-75 h-75 rounded-full bg-primary/12 blur-[32px]">
    </div>
  </div>
    <div class="absolute inset-0 opacity-[0.03] grid-bg"></div>

  <div class="container mx-auto px-6 relative z-10 text-center max-w-5xl">
    <div class="hero-content">

      <div class="inline-flex items-center gap-2 px-4 py-1.5 rounded-full border mb-8 text-xs font-semibold tracking-widest uppercase  bg-primary/10 text-primary">
        <span class="w-1.5 h-1.5 rounded-full animate-pulse bg-primary"></span>
        {badge}
      </div>

      <h1 class="font-display font-bold mb-6 text-[clamp(2.8rem,7vw,5.5rem)] leading-[1.08] tracking-[-0.01em]">
        <span class="text-foreground">{title}</span>
        <br />
        <span class="text-gradient">
          {highlight}
        </span>
      </h1>

      <p class="md:text-xl max-w-3xl mx-auto mb-3 font-bold leading-relaxed">
        <span>
          {description1}
        </span>
      </p>

      <p class="text-lg md:text-xl max-w-2xl mx-auto mb-10 leading-relaxed text-muted-foreground">
        {description2}
      </p>

      <div class="flex flex-col sm:flex-row gap-4 justify-center items-center">
        <a
          href={primaryCta.href}
          class="group inline-flex items-center gap-2 px-8 py-3.5 rounded-full text-sm font-semibold text-white bg-linear-to-br from-[#f58c5b] to-primary shadow-[0_0_25px] shadow-primary/35 ring-1 ring-inset ring-white/10 transition-all duration-300 hover:shadow-[0_0_40px] hover:shadow-primary/55 hover:-translate-y-0.5"
        >
          {primaryCta.text}
          <svg class="w-4 h-4 group-hover:translate-x-0.5 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3" />
          </svg>
        </a>
        <a
          href={secondaryCta.href}
          class="inline-flex items-center gap-2 px-8 py-3.5 rounded-full text-sm font-medium text-foreground/70 hover:text-foreground transition-all duration-300 border border-primary/20 hover:border-primary/45 bg-primary/4 hover:bg-primary/8"
        >
          {secondaryCta.text}
        </a>
      </div>

      <div class="mt-20 flex flex-col items-center gap-2 hero-scroll">
        <span class="text-[10px] tracking-[0.2em] uppercase text-primary">Scroll</span>
        <div class="w-px h-10 scroll-line"></div>
      </div>

    </div>
  </div>
</section>

<style>
  .grid-bg {
    background-image: linear-gradient(var(--color-primary, #4a8fe8) 1px, transparent 1px), 
                      linear-gradient(90deg, var(--color-primary, #4a8fe8) 1px, transparent 1px);
    background-size: 60px 60px;
  }

  .hero-content {
    animation: fadeUp 0.9s cubic-bezier(0.16, 1, 0.3, 1) forwards;
  }

  .scroll-line {
    width: 1px; 
    height: 40px;
    background: linear-gradient(to bottom, var(--color-primary, #4a8fe8), transparent);
    animation: scrollAnim 2s infinite;
  }

  @keyframes fadeUp {
    from { opacity: 0; transform: translateY(28px); }
    to   { opacity: 1; transform: translateY(0); }
  }

    @keyframes scrollAnim {
    0%   { transform: scaleY(0); transform-origin: bottom; }
    50%  { transform: scaleY(1); transform-origin: bottom; }
    51%  { transform: scaleY(1); transform-origin: top; }
    100% { transform: scaleY(0); transform-origin: top; }
  }
</style>