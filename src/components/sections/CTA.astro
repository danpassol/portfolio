---
import { ui, defaultLang } from '~/i18n/ui';
import Button from '~/components/ui/Button.astro';
import { useTranslations } from '~/i18n/utils';

const { lang = defaultLang } = Astro.params;
const t = useTranslations(lang);

interface Props {
  title?: string;
  description?: string;
  primaryBtn?: {
    text: string;
    href: string;
  };
  secondaryBtn?: {
    text: string;
    href: string;
  };
  disclaimer?: string;
  variant?: 'default' | 'boxed';
}

const { 
  title = t['cta.readyToLaunch'], 
  description = t['cta.description'], 
  primaryBtn = { text: t['cta.primary'], href: `/${lang}/contact` }, 
  secondaryBtn = { text: t['cta.secondary'], href: `/${lang}/about` }, 
  disclaimer = t['cta.disclaimer'],
  variant = 'default'
} = Astro.props;

const isBoxed = variant === 'boxed';
---
<section class={isBoxed ? "mt-24 max-w-4xl mx-auto px-6" : "py-32 relative overflow-hidden"}>
    {!isBoxed && (
      <div class="absolute inset-0 z-0 pointer-events-none" aria-hidden="true">
        <div class="absolute bottom-0 left-1/2 -translate-x-1/2 w-[900px] h-[500px] rounded-full bg-gradient-to-r from-primary/10 via-[#f58c5b]/5 to-transparent blur-[60px]">
        </div>
      </div>
    )}

    <div class={
      isBoxed
        ? "p-12 rounded-2xl text-white text-center relative overflow-hidden bg-linear-to-br from-primary/10 to-[#f58c5b]/10 border border-primary/20 backdrop-blur-sm"
        : "max-w-4xl mx-auto px-6 relative z-10 text-center"
    }
    >
        <h2
          class={isBoxed ? "text-3xl font-bold mb-4" : "font-display font-bold mb-8 leading-tight text-[clamp(2.5rem,6vw,5rem)]"}
          set:html={title}
        />

        <p class={`${isBoxed ? "mb-8 max-w-md mx-auto" : "text-xl mb-10 max-w-2xl mx-auto"} text-muted-foreground`}>
          {description}
        </p>

        <div class="flex flex-col sm:flex-row gap-4 justify-center items-center">
          
          <a href={primaryBtn.href}
            class="group inline-flex items-center gap-2 px-10 py-4 rounded-full text-base font-semibold text-white transition-all duration-300 bg-linear-to-br from-[#f58c5b] to-primary shadow-[0_0_28px] shadow-primary/40 hover:shadow-[0_0_45px] hover:shadow-primary/60 hover:-translate-y-0.5 ring-1 ring-inset ring-white/10"
          >
            {primaryBtn.text}
            <svg class="w-4 h-4 transition-transform group-hover:translate-x-1" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3" />
            </svg>
          </a>
          
          <a href={secondaryBtn.href}
            class="inline-flex items-center px-10 py-4 rounded-full text-base font-medium text-foreground/70 hover:text-foreground transition-all duration-300 border border-primary/20 hover:border-primary/45 bg-primary/5 hover:bg-primary/10"
          >
            {secondaryBtn.text}
          </a>
        </div>

        {disclaimer && !isBoxed && (
          <p class="mt-6 text-sm text-muted-foreground/60">{disclaimer}</p>
        )}
    </div>
</section>