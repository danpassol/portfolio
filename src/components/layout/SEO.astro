---
interface Props {
  title: string;
  description: string;
  image?: string;
  article?: boolean;
  noindex?: boolean;
  nofollow?: boolean;
  availableLangs?: string[];
}

const { title, description, image, article = false, noindex = false, nofollow = false, availableLangs } = Astro.props;
import { siteConfig } from '~/site.config';
import { defaultLang } from '~/i18n/ui';

const { lang = defaultLang } = Astro.params;

const canonicalURL = new URL(Astro.url.pathname, Astro.site).toString();
const ogImageUrl = image || siteConfig.ogImage;
const ogImageAbsolute = new URL(ogImageUrl, Astro.site).toString();

const robots = [
  noindex ? 'noindex' : 'index',
  nofollow ? 'nofollow' : 'follow'
].join(', ');

const localeMap: Record<string, string> = {
  es: 'es_ES',
  en: 'en_US',
};
const ogLocale = localeMap[lang] ?? 'es_ES';

// hreflang: genera alternate links para los idiomas disponibles
const supportedLangs = availableLangs ?? ['es', 'en'];
const hreflangLinks = supportedLangs.map((l) => {
  // Sustituye el segmento de idioma en la URL actual
  const altPath = Astro.url.pathname.replace(/^\/(es|en)/, `/${l}`);
  return {
    lang: l,
    url: new URL(altPath, Astro.site).toString(),
  };
});
---

<!-- Global Metadata -->
<meta charset="utf-8" />
<meta name="viewport" content="width=device-width,initial-scale=1" />
<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
<meta name="generator" content={Astro.generator} />

<!-- Robots -->
<meta name="robots" content={robots} />

<!-- Canonical URL -->
<link rel="canonical" href={canonicalURL} />

<!-- hreflang alternates -->
{hreflangLinks.map(({ lang: l, url }) => (
  <link rel="alternate" hreflang={l} href={url} />
))}
<link rel="alternate" hreflang="x-default" href={new URL(`/es${Astro.url.pathname.replace(/^\/(es|en)/, '')}`, Astro.site).toString()} />

<!-- RSS Feed -->
<link rel="alternate" type="application/rss+xml" title={siteConfig.name} href={new URL('/rss.xml', Astro.site).toString()} />

<!-- Primary Meta Tags -->
<title>{title}</title>
<meta name="title" content={title} />
<meta name="description" content={description} />

<!-- Open Graph -->
<meta property="og:type" content={article ? 'article' : 'website'} />
<meta property="og:site_name" content={siteConfig.name} />
<meta property="og:url" content={Astro.url.toString()} />
<meta property="og:locale" content={ogLocale} />
<meta property="og:title" content={title} />
<meta property="og:description" content={description} />
<meta property="og:image" content={ogImageAbsolute} />
<meta property="og:image:width" content="1200" />
<meta property="og:image:height" content="630" />
<meta property="og:logo" content={new URL(siteConfig.logo.src, Astro.site).toString()} />

<!-- Twitter -->
<meta name="twitter:card" content="summary_large_image" />
<meta name="twitter:url" content={Astro.url.toString()} />
<meta name="twitter:title" content={title} />
<meta name="twitter:description" content={description} />
<meta name="twitter:image" content={ogImageAbsolute} />